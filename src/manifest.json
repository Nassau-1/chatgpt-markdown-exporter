{
  "manifest_version": 3,
  "name": "ChatGPT Markdown Exporter",
  "version": "0.1.0",
  "description": "Export the current ChatGPT conversation to Markdown.",
  "permissions": [
    "downloads",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "action": {
    "default_title": "Export current conversation",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "lib/exporter-core.js",
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
